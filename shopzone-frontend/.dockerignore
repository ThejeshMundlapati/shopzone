# ============================================================
# ShopZone Frontend — .dockerignore
# ============================================================

# Dependencies (we install fresh inside Docker)
node_modules/

# Build output (we build inside Docker)
dist/

# Git
.git
.gitignore

# IDE
.vscode/
.idea/

# Environment files (passed via Docker build args)
.env
.env.local
.env.development

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Docker files (not needed inside the image)
Dockerfile
.dockerignore