# ============================================================
# ShopZone — Environment Variables Template
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains secrets!
# ============================================================

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=sk_test_your_actual_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_actual_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_actual_webhook_secret

# ==================== CLOUDINARY ====================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==================== MAILTRAP ====================
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@shopzone.com

# ==================== DATABASE (change for production) ====================
# These match the defaults in docker-compose.yml
# Only change if you want different credentials
# POSTGRES_USER=shopzone_admin
# POSTGRES_PASSWORD=shopzone_secret_2024